    <table id="report_power_power_summary" title="Power Summary" column_number="2">
        <column_headers>
            <data>Name</data>
            <data>Value</data>
        </column_headers>
        <comment>
            <data>Notice:</data>
            <data>    The result of power analysis is based on the voltage list in [Settings] -&gt; [Power Supply] table.</data>
            <data>    And no margin for power supply reserved.</data>
        </comment>
        <row>
