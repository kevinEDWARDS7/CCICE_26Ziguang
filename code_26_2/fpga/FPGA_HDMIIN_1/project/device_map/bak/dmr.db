    <table id="device_map_timing_constraint" title="Timing Constraint" column_number="1">
        <column_headers>
            <data>Command</data>
        </column_headers>
        <row>
            <data>create_clock -name {ref_clk} [get_ports {sys_clk}] -period {40.000} -waveform {0.000 20.000}</data>
        </row>
        <row>
            <data>create_generated_clock -name {rst_clk} -source [get_ports {sys_clk}] [get_pins {dl_I_ips_ddr_top.u_ddrphy_top.rst_clk_gpll/clkout0}] -master_clock [get_clocks {ref_clk}] -multiply_by {84} -divide_by {84}</data>
        </row>
        <row>
            <data>create_generated_clock -name {ddrphy_sysclk} -source [get_ports {sys_clk}] [get_pins {dl_I_ips_ddr_top.u_ddrphy_top.ddrphy_gpll/clkout0}] -master_clock [get_clocks {ref_clk}] -multiply_by {84} -divide_by {16}</data>
        </row>
        <row>
            <data>create_generated_clock -name {phy_dq_clk_0} -source [get_ports {sys_clk}] [get_pins {dl_I_ips_ddr_top.u_ddrphy_top.ddrphy_slice_top.i_dqs_bank[0].ddrphy_ppll/clkoutphy}] -master_clock [get_clocks {ref_clk}] -multiply_by {84} -divide_by {2}</data>
        </row>
        <row>
            <data>create_generated_clock -name {phy_dq_sysclk_0} -source [get_pins {dl_I_ips_ddr_top.u_ddrphy_top.ddrphy_slice_top.i_dqs_bank[0].ddrphy_ppll/clkoutphy}] [get_pins {dl_I_ips_ddr_top.u_ddrphy_top.ddrphy_slice_top.i_dqs_bank[0].u_ddrphy_ioclkdiv/CLKDIVOUT}] -master_clock [get_clocks {phy_dq_clk_0}] -edges {5 13 21} -edge_shift {0 0 0}</data>
        </row>
        <row>
            <data>create_generated_clock -name {phy_dq_clk_1} -source [get_ports {sys_clk}] [get_pins {dl_I_ips_ddr_top.u_ddrphy_top.ddrphy_slice_top.i_dqs_bank[1].ddrphy_ppll/clkoutphy}] -master_clock [get_clocks {ref_clk}] -multiply_by {84} -divide_by {2}</data>
        </row>
        <row>
            <data>create_generated_clock -name {phy_dq_sysclk_1} -source [get_pins {dl_I_ips_ddr_top.u_ddrphy_top.ddrphy_slice_top.i_dqs_bank[1].ddrphy_ppll/clkoutphy}] [get_pins {dl_I_ips_ddr_top.u_ddrphy_top.ddrphy_slice_top.i_dqs_bank[1].u_ddrphy_ioclkdiv/CLKDIVOUT}] -master_clock [get_clocks {phy_dq_clk_1}] -edges {5 13 21} -edge_shift {0 0 0}</data>
        </row>
        <row>
            <data>create_clock -name {pclk} [get_pins {dl_u_ips2l_pcie_wrap.U_IPS2L_PCIE_TOP.U_IPS2L_HSSTLP_PCIE_SOFT_PHY.pclk}] -period {4.000} -waveform {0.000 2.000}</data>
        </row>
        <row>
            <data>create_clock -name {pclk_div2} [get_pins {dl_u_ips2l_pcie_wrap.U_IPS2L_PCIE_TOP.U_IPS2L_HSSTLP_PCIE_SOFT_PHY.pclk_div2}] -period {8.000} -waveform {0.000 4.000}</data>
        </row>
        <row>
            <data>create_clock -name {ref_clk1} [get_pins {dl_u_ips2l_pcie_wrap.U_IPS2L_PCIE_TOP.U_IPS2L_HSSTLP_PCIE_SOFT_PHY/P_REFCK2CORE_0}] -period {10.000} -waveform {0.000 5.000}</data>
        </row>
        <row>
            <data>create_generated_clock -name {clk_10m} -source [get_ports {sys_clk}] [get_nets {dl_pll_inst.clkout0}] -master_clock [get_clocks {ref_clk}] -multiply_by {2} -divide_by {5}</data>
        </row>
        <row>
            <data>create_generated_clock -name {clk_25m} -source [get_ports {sys_clk}] [get_nets {dl_pll_inst.clkout1}] -master_clock [get_clocks {ref_clk}] -multiply_by {1} -divide_by {1}</data>
        </row>
        <row>
            <data>create_generated_clock -name {clk_50m} -source [get_ports {sys_clk}] [get_nets {dl_pll_inst.clkout2}] -master_clock [get_clocks {ref_clk}] -multiply_by {2} -divide_by {1}</data>
        </row>
        <row>
            <data>create_clock -name {hdmi_pix_clk} [get_ports {hdmi_pix_clk}] -period {6.670} -waveform {0.000 3.335}</data>
        </row>
        <row>
            <data>set_clock_groups -name ref_clk -asynchronous -group [get_clocks {ref_clk}]</data>
        </row>
        <row>
            <data>set_clock_groups -name rst_clk -asynchronous -group [get_clocks {rst_clk}]</data>
        </row>
        <row>
            <data>set_clock_groups -name phy_dq_clk_0 -asynchronous -group [get_clocks {phy_dq_clk_0}]</data>
        </row>
        <row>
            <data>set_clock_groups -name phy_dq_clk_1 -asynchronous -group [get_clocks {phy_dq_clk_1}]</data>
        </row>
        <row>
            <data>set_clock_groups -name group_1 -asynchronous -group [get_clocks {pclk}]</data>
        </row>
        <row>
            <data>set_clock_groups -name group_2 -asynchronous -group [get_clocks {pclk_div2}]</data>
        </row>
        <row>
            <data>set_clock_groups -name group_3 -asynchronous -group [get_clocks {ref_clk1}]</data>
        </row>
        <row>
            <data>set_clock_uncertainty {0.4} -from [get_clocks {ddrphy_sysclk}] -to [get_clocks {phy_dq_sysclk_0}] -setup -hold</data>
        </row>
        <row>
            <data>set_clock_uncertainty {0.4} -from [get_clocks {phy_dq_sysclk_0}] -to [get_clocks {ddrphy_sysclk}] -setup -hold</data>
        </row>
        <row>
            <data>set_clock_uncertainty {0.4} -from [get_clocks {ddrphy_sysclk}] -to [get_clocks {phy_dq_sysclk_1}] -setup -hold</data>
        </row>
        <row>
            <data>set_clock_uncertainty {0.4} -from [get_clocks {phy_dq_sysclk_1}] -to [get_clocks {ddrphy_sysclk}] -setup -hold</data>
        </row>
        <row>
            <data>set_multicycle_path 2 -from [get_clocks ddrphy_sysclk] -to [get_clocks phy_dq_sysclk_0]</data>
        </row>
        <row>
            <data>set_multicycle_path 2 -from [get_clocks ddrphy_sysclk] -to [get_clocks phy_dq_sysclk_1]</data>
        </row>
    </table>
