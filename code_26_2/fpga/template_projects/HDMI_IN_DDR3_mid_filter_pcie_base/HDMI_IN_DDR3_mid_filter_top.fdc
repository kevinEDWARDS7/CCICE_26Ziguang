# =========================================================
# 1. КЫаФЯЕЭГЪБжг & PCIe ЪБжг (длУЧМмЙЙЕФУќТі)
# =========================================================
# 125MHz ЯЕЭГжїЪБжг
define_attribute {p:clk_p} {PAP_IO_LOC} {R4}
define_attribute {p:clk_p} {PAP_IO_DIRECTION} {INPUT}
define_attribute {p:clk_p} {PAP_IO_VCCIO} {1.5}
define_attribute {p:clk_p} {PAP_IO_STANDARD} {SSTL15D_I}

define_attribute {p:clk_n} {PAP_IO_LOC} {T4}
define_attribute {p:clk_n} {PAP_IO_DIRECTION} {INPUT}
define_attribute {p:clk_n} {PAP_IO_VCCIO} {1.5}
define_attribute {p:clk_n} {PAP_IO_STANDARD} {SSTL15D_I}

# PCIe 100MHz ВЮПМЪБжг
define_attribute {p:pcie_refclk_p} {PAP_IO_LOC} {F6}
define_attribute {p:pcie_refclk_p} {PAP_IO_DIRECTION} {INPUT}
define_attribute {p:pcie_refclk_p} {PAP_IO_VCCIO} {3.3}
define_attribute {p:pcie_refclk_p} {PAP_IO_STANDARD} {LVDS}

define_attribute {p:pcie_refclk_n} {PAP_IO_LOC} {E6}
define_attribute {p:pcie_refclk_n} {PAP_IO_DIRECTION} {INPUT}
define_attribute {p:pcie_refclk_n} {PAP_IO_VCCIO} {3.3}
define_attribute {p:pcie_refclk_n} {PAP_IO_STANDARD} {LVDS}

# =========================================================
# 2. 40pin РЉеЙПкЃКHDMI IN згПЈдМЪј (ЙйЗН V1.1 БъзМ)
# =========================================================

# -----------------
# ЪБжгдМЪј
# -----------------
# 7В215 зЂвтЃКетРяФЌШЯАДее V1.1 згПЈХфжУЃЌpixclk_in ЮЊ W19ЁЃ
# 7В215 ШчЙћЪЧ V1.0 згПЈЃЌЧыНЋ W19 ИФЮЊ W20ЁЃ
create_clock -name {pix_clk_in} [get_ports {pixclk_in}] -period {6.670} -waveform {0.000 3.335}
define_attribute {p:pixclk_in} {PAP_IO_DIRECTION} {INPUT}
define_attribute {p:pixclk_in} {PAP_IO_LOC} {W19} 
define_attribute {p:pixclk_in} {PAP_IO_VCCIO} {3.3}
define_attribute {p:pixclk_in} {PAP_IO_STANDARD} {LVCMOS33}
define_attribute {p:pixclk_in} {PAP_IO_NONE} {TRUE}
# БмУтЪБжгВМЯпБЈДэЃЌдЪаэЗЧШЋОжЪБжгЙмНХВМЯп
define_attribute {n:pixclk_in} {PAP_CLOCK_DEDICATED_ROUTE} {false}

