# -----------------
# I2C МАИДЮЛ
# -----------------
# 7В215 ЙйЗНЪОР§РяжЛга sys_clkЃЌВЂУЛгаИјФу rstn_out ЕФЮяРэЙмНХЁЃ
# длУЧжЎЧАгУЕФЪЧ L13ЃЌЯждкЮвАбЫќЛжИДГЩЙйЗНвЊЧѓЕФаќПезДЬЌЃЌЛђепФуевИіПеЯав§НХ
# етРяЮвднЪБЗжХфИј L13ЃЌШчЙћзлКЯБЈДэЫЕЙмНХГхЭЛЃЌФуЫцБуЛЛвЛИіРЉеЙПкЩЯУЛгУЕНЕФЙмНХМДПЩЁЃ
define_attribute {p:rstn_out} {PAP_IO_DIRECTION} {OUTPUT}
define_attribute {p:rstn_out} {PAP_IO_LOC} {L13} 
define_attribute {p:rstn_out} {PAP_IO_VCCIO} {3.3}
define_attribute {p:rstn_out} {PAP_IO_STANDARD} {LVCMOS33}

# hd_sda
define_attribute {p:hd_sda} {PAP_IO_DIRECTION} {INOUT}
define_attribute {p:hd_sda} {PAP_IO_LOC} {AA20}
define_attribute {p:hd_sda} {PAP_IO_VCCIO} {3.3}
define_attribute {p:hd_sda} {PAP_IO_STANDARD} {LVCMOS33}
define_attribute {p:hd_sda} {PAP_IO_DRIVE} {4}
define_attribute {p:hd_sda} {PAP_IO_PULLUP} {TRUE}
define_attribute {p:hd_sda} {PAP_IO_SLEW} {FAST}

# hd_scl
define_attribute {p:hd_scl} {PAP_IO_DIRECTION} {INOUT}  
define_attribute {p:hd_scl} {PAP_IO_LOC} {AA21}
define_attribute {p:hd_scl} {PAP_IO_VCCIO} {3.3}
define_attribute {p:hd_scl} {PAP_IO_STANDARD} {LVCMOS33}
define_attribute {p:hd_scl} {PAP_IO_DRIVE} {4}
define_attribute {p:hd_scl} {PAP_IO_PULLUP} {TRUE}
define_attribute {p:hd_scl} {PAP_IO_SLEW} {FAST}

