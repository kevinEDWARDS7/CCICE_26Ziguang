#region agent log
proc agent_debug_log {runId hypothesisId location message} {
    if {[catch {
        set f [open {F:/CursorProject/CCICE_26Ziguang/debug-6f1e7e.log} a]
        puts $f "{\"sessionId\":\"6f1e7e\",\"runId\":\"$runId\",\"hypothesisId\":\"$hypothesisId\",\"location\":\"$location\",\"message\":\"$message\",\"data\":{},\"timestamp\":[clock milliseconds]}"
        close $f
    }]} {}
}
